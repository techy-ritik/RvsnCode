<%- include('../includes/head.ejs') %>
    </head>

    <body>
        <%- include('../includes/navigation.ejs') %>
        <main>
            <% if(products.length>0){ %>
                <ul>
                    <% products.forEach(crntP=>{ %>
                        <li><%= crntP.productData.title %> (<%= crntP.qty %>)</li>   <!-- here we want to display only title and qty of the product so we have to pass them individually with the help of ejs and not complete product -->
                    <% }) %>
                </ul>
            <% }else{ %>
                <h1>no Products Avaialble in cart...</h1>
            <% } %>
        </main>
        <%- include('../includes/end.ejs') %>
        